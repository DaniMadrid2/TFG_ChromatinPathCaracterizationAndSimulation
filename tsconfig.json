{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": [
      "DOM",
      "ES2020"
    ],
    "types": ["node"],
    "rootDir": "src",
    "strict": false,
    "skipLibCheck": true,
    "noEmitOnError": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": false
  },
  "include": [
    "src/main.ts",
    "src/dependencies/assets/**/*.ts"
  ]
}
